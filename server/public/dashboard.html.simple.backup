<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Heidi Pacella — Voter Dashboard</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <style>
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap');

:root{
  --navy:#0B1929;
  --navy-mid:#122338;
  --navy-light:#1A3550;
  --gold:#F5A623;
  --gold-light:#FBBF48;
  --red:#E03434;
  --green:#1DB87A;
  --ice:#EAF3FF;
  --text:#EEF2F7;
  --text-muted:#8BA3BE;
  --border:#243D56;
  --surface:#122338;
  --surface-2:#1A3550;
  --radius:10px;
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Barlow',sans-serif;
  background:var(--navy);
  color:var(--text);
  font-size:14px;
  min-height:100vh;
}

body::before{
  content:'';
  position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events:none;z-index:0;opacity:.5;
}

.container{max-width:1320px;margin:0 auto;padding:1.5rem;position:relative;z-index:1}

header{
  position:relative;overflow:hidden;
  background:linear-gradient(135deg,#0B1929 0%,#122338 40%,#1A3550 100%);
  border:1px solid var(--border);
  border-radius:16px;
  padding:20px 24px;
  margin-bottom:1.5rem;
  box-shadow:0 8px 40px rgba(0,0,0,.5);
}

header::before{
  content:'';
  position:absolute;top:-40px;right:-40px;
  width:280px;height:280px;
  background:radial-gradient(circle,rgba(245,166,35,.12) 0%,transparent 70%);
  pointer-events:none;
}

header::after{
  content:'';
  position:absolute;bottom:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--gold),#F5A62300);
}

h1{
  font-family:'Barlow Condensed',sans-serif;
  font-size:26px;font-weight:800;letter-spacing:.02em;
  color:#fff;
  text-transform:uppercase;
  line-height:1;
  margin-bottom:5px;
  position:relative;z-index:1;
}

.subtitle{
  font-size:12px;color:var(--text-muted);letter-spacing:.03em;
  position:relative;z-index:1;
}

.controls{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:16px;
  margin-bottom:1rem;
}

.control-group{display:flex;flex-direction:column;gap:5px;margin-bottom:15px;}
label{font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;}

input,select{
  font-size:12px;padding:7px 10px;font-family:'Barlow',sans-serif;
  border:1px solid var(--border);border-radius:8px;
  background:var(--navy);color:var(--text);
  transition:border-color .15s;
  width:100%;max-width:300px;
}
input:focus,select:focus{outline:none;border-color:var(--gold);}
input::placeholder{color:var(--text-muted);}

button{
  font-size:12px;padding:7px 14px;font-family:'Barlow',sans-serif;font-weight:600;
  border:1px solid var(--border);border-radius:8px;
  background:var(--gold);color:#0B1929;
  cursor:pointer;transition:all .15s;letter-spacing:.02em;
  display:inline-block;margin-right:6px;margin-top:10px;
}
button:hover{background:var(--gold-light);box-shadow:0 4px 16px rgba(245,166,35,.35);}

.status{
  padding:10px 15px;border-radius:8px;margin-bottom:10px;
  font-size:13px;border:1px solid var(--border);
  background:var(--surface);color:var(--text-muted);
}
.status.success{background:rgba(29,184,122,.15);color:var(--green);border-color:var(--green);}
.status.error{background:rgba(224,52,52,.15);color:var(--red);border-color:var(--red);}

.table-wrap{
  border:1px solid var(--border);border-radius:var(--radius);
  overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:1rem;
  box-shadow:0 4px 20px rgba(0,0,0,.25);
}

table{width:100%;border-collapse:collapse;font-size:12px;}
th{
  font-size:10px;font-weight:700;color:var(--text-muted);
  padding:10px;background:var(--surface);
  border-bottom:1px solid var(--border);
  text-align:left;white-space:nowrap;
  cursor:pointer;text-transform:uppercase;letter-spacing:.06em;
}
th:hover{color:var(--gold);}
td{
  padding:9px 10px;border-bottom:1px solid rgba(36,61,86,.6);
  color:var(--text);overflow:hidden;text-overflow:ellipsis;
  white-space:nowrap;vertical-align:middle;background:var(--navy);
}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--surface);}

.score{font-weight:700;color:var(--gold);}

.pagination{
  margin-top:20px;display:flex;gap:8px;justify-content:center;flex-wrap:wrap;
}
.pagination button{
  padding:6px 12px;font-size:11px;
  background:var(--surface);color:var(--text);border:1px solid var(--border);
  margin:0;margin-right:0;
}
.pagination button:hover{background:var(--surface-2);}
.pagination button.active{background:var(--gold);color:#0B1929;border-color:var(--gold);}
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Heidi Pacella — <span style="color: var(--gold);">Voter Dashboard</span></h1>
      <p class="subtitle">Campaign Outreach & Super Picks Identification</p>
    </header>

    <div class="controls">
      <div class="control-group">
        <label>Show Voters:</label>
        <select id="viewType">
          <option value="all">All Voters</option>
          <option value="super-picks">Super Picks (High Priority)</option>
        </select>
      </div>
      <div class="control-group">
        <label>Min Super Picks Score:</label>
        <input type="number" id="minScore" value="70" min="0" max="100">
      </div>
      <div class="control-group">
        <label>Precinct Filter:</label>
        <input type="text" id="precinctFilter" placeholder="e.g., Precinct 001">
      </div>
      <button onclick="loadVoters()">Apply Filters</button>
      <button onclick="exportCSV()" style="background: #666;">Export CSV</button>
      <button onclick="window.location.href='map.html'" style="background: #28a745; margin-left: 10px;">📍 View Map</button>
    </div>

    <div id="status"></div>

    <div class="table-wrap">
    <table id="votersTable">
      <thead>
        <tr>
          <th>Name</th>
          <th>Phone</th>
          <th>Address</th>
          <th>Precinct</th>
          <th>Party</th>
          <th class="score">Super Picks Score</th>
        </tr>
      </thead>
      <tbody id="votersBody">
        <tr><td colspan="6" style="text-align: center;">Loading voters...</td></tr>
      </tbody>
    </table>
    </div>

    <div class="pagination" id="pagination"></div>
  </div>

  <script>
    const API_BASE = 'http://localhost:5000/api';
    let allVoters = [];
    let currentPage = 1;
    const pageSize = 50;

    async function loadVoters() {
      showStatus('loading', 'Loading voters...');
      try {
        const viewType = document.getElementById('viewType').value;
        const minScore = parseInt(document.getElementById('minScore').value) || 70;
        const precinct = document.getElementById('precinctFilter').value.trim() || null;

        console.log('DEBUG: viewType=' + viewType + ', minScore=' + minScore + ', precinct=' + precinct);

        let url;
        if (viewType === 'super-picks') {
          url = `${API_BASE}/super-picks?minScore=${minScore}&limit=20000`;
          if (precinct) url += `&precinct=${precinct}`;
        } else {
          url = `${API_BASE}/voters?limit=20000`;
          if (precinct) url += `&precinct=${precinct}`;
        }

        console.log('DEBUG: Calling API URL=' + url);
        const response = await fetch(url, {
          headers: {
            'Authorization': `Bearer ${localStorage.getItem('token')}`
          }
        });

        if (!response.ok) throw new Error(`HTTP ${response.status}`);

        const data = await response.json();
        console.log('DEBUG: API response keys:', Object.keys(data));
        console.log('DEBUG: superPicks count:', data.superPicks ? data.superPicks.length : 'N/A');
        console.log('DEBUG: voters count:', data.voters ? data.voters.length : 'N/A');
        allVoters = viewType === 'super-picks' ? data.superPicks : data.voters;
        console.log('DEBUG: allVoters.length=' + allVoters.length);
        currentPage = 1;
        renderPage();
        showStatus('success', `Loaded ${allVoters.length} voters`);
      } catch (err) {
        showStatus('error', `Error loading voters: ${err.message}`);
        document.getElementById('votersBody').innerHTML = '<tr><td colspan="6">Error loading voters</td></tr>';
      }
    }

    function renderPage() {
      const start = (currentPage - 1) * pageSize;
      const end = start + pageSize;
      const pageVoters = allVoters.slice(start, end);

      document.getElementById('votersBody').innerHTML = pageVoters.map(v => `
        <tr>
          <td>${(v.firstName || v.first_name || '')} ${(v.lastName || v.last_name || '')}</td>
          <td>${v.phone || ''}</td>
          <td>${v.address || ''}</td>
          <td>${v.precinct || v.precinct_name || ''}</td>
          <td>${v.partyAffiliation || v.party_affiliation || ''}</td>
          <td class="score">${v.superPickScore ? v.superPickScore.toFixed(0) : '—'}</td>
        </tr>
      `).join('');

      // Pagination
      const totalPages = Math.ceil(allVoters.length / pageSize);
      const pagination = document.getElementById('pagination');
      pagination.innerHTML = '';
      for (let i = 1; i <= Math.min(totalPages, 10); i++) {
        const btn = document.createElement('button');
        btn.textContent = i;
        btn.className = i === currentPage ? 'active' : '';
        btn.onclick = () => { currentPage = i; renderPage(); };
        pagination.appendChild(btn);
      }
    }

    function exportCSV() {
      if (allVoters.length === 0) {
        alert('No voters to export');
        return;
      }
      const headers = ['First Name', 'Last Name', 'Phone', 'Address', 'Precinct', 'Party', 'Score'];
      const rows = allVoters.map(v => [
        v.firstName, v.lastName, v.phone, v.address, v.precinct || v.precinct_name, v.partyAffiliation || v.party_affiliation,
        v.superPickScore ? v.superPickScore.toFixed(0) : ''
      ]);

      const csv = [headers, ...rows].map(r => r.map(c => `"${c || ''}"`).join(',')).join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `voters_${new Date().toISOString().slice(0, 10)}.csv`;
      a.click();
    }

    function showStatus(type, message) {
      const el = document.getElementById('status');
      el.className = `status ${type}`;
      el.textContent = message;
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      let token = localStorage.getItem('token');
      if (!token) {
        // Auto-generate test token for development
        token = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOjEsImVtYWlsIjoidGVzdEBleGFtcGxlLmNvbSIsInJvbGUiOiJhZG1pbiIsImlhdCI6MTc3ODQ3MTg3MywiZXhwIjoxNzc4NTAwNjczfQ.fyEAJ2qTQ5aiFKkKJuniUday3a29-LdDq-CQWdn4w3k';
        localStorage.setItem('token', token);
        console.log('DEBUG: Auto-set test token');
      }
      console.log('DEBUG: Starting loadVoters()');
      loadVoters();
    });
  </script>
</body>
</html>
