# Database (Railway will provide this for PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Secrets (generate with: openssl rand -base64 32)
SESSION_SECRET=CHANGE_ME_to_a_long_random_string_at_least_32_chars
JWT_SECRET=CHANGE_ME_to_a_different_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# Server config
PORT=5000
NODE_ENV=production

# Client URL (replace with your Railway deployment domain)
CLIENT_URL=https://your-railway-app.railway.app

# AWS SMS (SNS)
# Note: AWS credentials come from IAM role on EB; this just sets the region
AWS_SNS_REGION=us-east-1
