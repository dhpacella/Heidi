# Local Development Environment Variables
# Copy this to .env.local and fill in your values

NODE_ENV=production
PORT=8081

# PostgreSQL Database (RDS)
DATABASE_URL=postgresql://username:password@heidi-voter-db-east2.cf6y8ieas57y.us-east-2.rds.amazonaws.com:5432/postgres?sslmode=require

# AWS Configuration
AWS_REGION=us-east-2
AWS_SES_REGION=us-east-2
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Application URLs
APP_BASE_URL=http://localhost:8081
VOLUNTEER_PORTAL_URL=http://localhost:8081/volunteer-portal

# Session Secret (use a random string)
SESSION_SECRET=your-random-session-secret-key-change-this

# Email Configuration
SES_FROM_EMAIL=heidi@hadleytrees.com
